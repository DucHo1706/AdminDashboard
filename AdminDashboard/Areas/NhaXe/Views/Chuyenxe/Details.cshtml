@using AdminDashboard.Models.TrangThai
@using AdminDashboard.Helpers
@model AdminDashboard.Models.ChuyenXe

@{
    ViewData["Title"] = "Chi tiết chuyến xe " + Model.ChuyenId;
}

<style>
    /* --- VARIABLES & THEME --- */
    :root {
        --primary-color: #003366;
        --accent-color: #FF6600;
        --bg-gray: #f4f6f8;
        --card-border: #e9ecef;
    }

    body {
        background-color: var(--bg-gray);
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    /* --- LAYOUT CARDS --- */
    .detail-card {
        background: white;
        border-radius: 12px;
        border: 1px solid var(--card-border);
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        margin-bottom: 24px;
        overflow: hidden;
    }

    .card-header-custom {
        padding: 16px 24px;
        border-bottom: 1px solid var(--card-border);
        background: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-title {
        font-weight: 700;
        color: var(--primary-color);
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .card-body-custom {
        padding: 24px;
    }

    /* --- TIMELINE HÀNH TRÌNH (DỌC) --- */
    .journey-timeline {
        position: relative;
        padding-left: 35px;
        border-left: 2px dashed #e9ecef;
        margin-left: 10px;
    }

    .timeline-point {
        position: relative;
        margin-bottom: 40px;
    }

        .timeline-point:last-child {
            margin-bottom: 0;
        }

    .point-dot {
        position: absolute;
        left: -42px; /* Căn chỉnh chấm tròn đè lên đường kẻ */
        top: 0;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: white;
        border: 3px solid var(--accent-color);
        box-shadow: 0 0 0 4px white;
    }

        .point-dot.end {
            border-color: #28a745;
        }

    .time-big {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary-color);
        line-height: 1;
        margin-bottom: 4px;
    }

    .station-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: #333;
    }

    .station-address {
        color: #6c757d;
        font-size: 0.9rem;
        margin-top: 4px;
    }

    .duration-badge {
        display: inline-block;
        background: #e7f1ff;
        color: #0c63e4;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        margin: 10px 0 30px 0;
    }

    /* --- DRIVER & CAR INFO --- */
    .info-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        border-bottom: 1px solid #f8f9fa;
        padding-bottom: 12px;
    }

        .info-row:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

    .info-label {
        color: #6c757d;
        font-size: 0.9rem;
    }

    .info-value {
        font-weight: 600;
        color: #333;
    }

    .driver-profile {
        display: flex;
        align-items: center;
        gap: 15px;
        background: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
    }

    .driver-avatar {
        width: 48px;
        height: 48px;
        background: #dee2e6;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #6c757d;
    }

    /* --- STATUS BADGES --- */
    .status-badge-lg {
        padding: 6px 16px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .bg-success-light {
        background: #d1e7dd;
        color: #0f5132;
    }

    .bg-warning-light {
        background: #fff3cd;
        color: #664d03;
    }

    .bg-danger-light {
        background: #f8d7da;
        color: #842029;
    }

    .bg-secondary-light {
        background: #e2e3e5;
        color: #41464b;
    }

    /* --- IMAGE GRID --- */
    .car-image {
        width: 100%;
        height: 150px;
        object-fit: cover;
        border-radius: 8px;
        cursor: pointer;
        transition: transform 0.2s;
    }

        .car-image:hover {
            transform: scale(1.02);
        }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Chi tiết chuyến xe</h4>
            <div class="text-muted small">Mã chuyến: <strong>@Model.ChuyenId</strong></div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
            <a asp-action="Edit" asp-route-id="@Model.ChuyenId" class="btn btn-primary" style="background-color: var(--primary-color); border: none;">
                <i class="bi bi-pencil-square"></i> Chỉnh sửa
            </a>
            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                <i class="bi bi-trash"></i> Xóa
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="detail-card">
                <div class="card-header-custom">
                    <span class="header-title"><i class="bi bi-map"></i> Lộ trình & Thời gian</span>

                    @{
                        string badgeClass = "bg-secondary-light";
                        if (Model.TrangThai == TrangThaiChuyenXe.DangMoBanVe) { badgeClass = "bg-success-light"; }
                        else if (Model.TrangThai == TrangThaiChuyenXe.ChoKhoiHanh) { badgeClass = "bg-warning-light"; }
                        else if (Model.TrangThai == TrangThaiChuyenXe.DaHuy) { badgeClass = "bg-danger-light"; }
                    }
                    <span class="status-badge-lg @badgeClass">
                        @Model.TrangThai.GetDisplayName()
                    </span>
                </div>
                <div class="card-body-custom">
                    <div class="journey-timeline">
                        <div class="timeline-point">
                            <div class="point-dot"></div>
                            <div class="time-big">@Model.GioDi.ToString(@"hh\:mm")</div>
                            <div class="text-muted fw-bold mb-1">@Model.NgayDi.ToString("dd/MM/yyyy")</div>
                            <div class="station-name">@Model.LoTrinh?.TramDiNavigation?.TenTram</div>
                            <div class="station-address">
                                <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                                @(Model.LoTrinh?.TramDiNavigation?.DiaChiTram ?? "Đang cập nhật địa chỉ")
                            </div>
                        </div>

                        @* <div class="ps-2">
                            <span class="duration-badge">
                                <i class="bi bi-hourglass-split"></i> Dự kiến chạy @(Model.LoTrinh?. ?? 0) tiếng
                            </span>
                        </div> *@

                        <div class="timeline-point">
                            <div class="point-dot end"></div>
                            @* <div class="time-big">
                                @{
                                    // var timeArrive = Model.GioDi.Add(TimeSpan.FromHours(Model.LoTrinh?.ThoiGianDuKien ?? 0));
                                }
                                @timeArrive.ToString(@"hh\:mm") <small class="text-muted fs-6 fw-normal">(Dự kiến)</small>
                            </div> *@
                            <div class="text-muted fw-bold mb-1">@Model.NgayDi.ToString("dd/MM/yyyy")</div> <div class="station-name">@Model.LoTrinh?.TramToiNavigation?.TenTram</div>
                            <div class="station-address">
                                <i class="bi bi-geo-alt-fill text-success me-1"></i>
                                @(Model.LoTrinh?.TramToiNavigation?.DiaChiTram ?? "Đang cập nhật địa chỉ")
                            </div>
                        </div>
                    </div>

                    <hr class="mt-4 mb-3" />
@* 
                    <div class="row">
                        <div class="col-md-6">
                            <div class="info-row">
                                <span class="info-label">Khoảng cách:</span>
                                <span class="info-value">@(Model.LoTrinh?. ?? 0) Km</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-row">
                                <span class="info-label">Giá vé niêm yết:</span>
                                <span class="info-value text-success fs-5">@String.Format("{0:0,0}", Model.GiaVe) đ</span>
                            </div>
                        </div>
                    </div> *@
                </div>
            </div>

            @if (Model.Images != null && Model.Images.Any())
            {
                <div class="detail-card">
                    <div class="card-header-custom">
                        <span class="header-title"><i class="bi bi-images"></i> Hình ảnh phương tiện</span>
                    </div>
                    <div class="card-body-custom">
                        <div class="row g-3">
                            @foreach (var img in Model.Images)
                            {
                                <div class="col-md-4 col-6">
                                    <img src="@img.ImageUrl" class="car-image shadow-sm" alt="Hình ảnh xe">
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="detail-card">
                <div class="card-header-custom">
                    <span class="header-title"><i class="bi bi-bus-front"></i> Thông tin xe</span>
                </div>
                <div class="card-body-custom">
                    <div class="text-center mb-4">
                        <div class="d-inline-block border border-dark px-3 py-1 rounded bg-warning fw-bold">
                            @Model.Xe?.BienSoXe
                        </div>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Loại xe:</span>
                        <span class="info-value">@Model.Xe?.LoaiXe?.TenLoaiXe</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Số ghế:</span>
                        <span class="info-value">@Model.Xe?.DanhSachGhe chỗ</span>
                    </div>
@*                     <div class="info-row">
                        <span class="info-label">Màu xe:</span>
                        <span class="info-value">@(Model.Xe?. ?? "N/A")</span>
                    </div> *@
                </div>
            </div>

            <div class="detail-card">
                <div class="card-header-custom">
                    <span class="header-title"><i class="bi bi-person-badge"></i> Tài xế phụ trách</span>
                    <a asp-action="PhanCong" asp-route-id="@Model.ChuyenId" class="small text-decoration-none fw-bold text-primary">Đổi</a>
                </div>
                <div class="card-body-custom">
                    @if (!string.IsNullOrEmpty(Model.TaiXeId))
                    {
                        <div class="driver-profile">
                            <div class="driver-avatar">
                                @(Model.TaiXe?.HoTen?.Substring(0, 1) ?? "T")
                            </div>
                            <div>
                                <div class="fw-bold text-dark">@Model.TaiXe?.HoTen</div>
                                <div class="small text-muted"><i class="bi bi-telephone"></i> @Model.TaiXe?.SoDienThoai</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3">
                            <p class="text-muted small mb-3">Chưa có tài xế nào được phân công.</p>
                            <a asp-action="PhanCong" asp-route-id="@Model.ChuyenId" class="btn btn-sm btn-outline-warning w-100 fw-bold">
                                <i class="bi bi-plus-circle"></i> Phân công ngay
                            </a>
                        </div>
                    }
                </div>
            </div>

            <div class="text-muted small px-2">
                <p class="mb-1"><i class="bi bi-clock-history"></i> Cập nhật lần cuối: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
                <p class="mb-0"><i class="bi bi-info-circle"></i> ID Hệ thống: @Model.ChuyenId</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white border-0">
                <h5 class="modal-title">Xác nhận Xóa</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p>Bạn có chắc chắn muốn xóa chuyến xe <strong>@Model.ChuyenId</strong> không?</p>
                <small class="text-danger">Hành động này không thể hoàn tác!</small>
            </div>
            <div class="modal-footer border-0 justify-content-center">
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.ChuyenId" />
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger px-4">Xóa ngay</button>
                </form>
            </div>
        </div>
    </div>
</div>