@model AdminDashboard.Models.ViewModels.NhanBanChuyenXeRequest
@using AdminDashboard.Models

@{
    ViewData["Title"] = "Nhân bản chuyến xe";
    var sourceTrip = ViewBag.SourceTrip as ChuyenXe;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Nhân bản chuyến xe</h2>
            <p class="text-muted mb-0">Áp dụng Prototype Pattern để tạo nhanh chuyến mới từ chuyến gốc.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    @if (sourceTrip != null)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <strong>Chuyến gốc đang dùng làm mẫu</strong>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="small text-muted">Mã chuyến</div>
                        <div class="fw-semibold">@sourceTrip.ChuyenId</div>
                    </div>

                    <div class="col-md-3">
                        <div class="small text-muted">Ngày đi</div>
                        <div class="fw-semibold">@sourceTrip.NgayDi.ToString("dd/MM/yyyy")</div>
                    </div>

                    <div class="col-md-3">
                        <div class="small text-muted">Giờ đi</div>
                        <div class="fw-semibold">@sourceTrip.GioDi.ToString(@"hh\:mm")</div>
                    </div>

                    <div class="col-md-3">
                        <div class="small text-muted">Giờ đến dự kiến</div>
                        <div class="fw-semibold">@sourceTrip.GioDenDuKien.ToString(@"hh\:mm")</div>
                    </div>

                    <div class="col-md-6">
                        <div class="small text-muted">Lộ trình</div>
                        <div class="fw-semibold">
                            @sourceTrip.LoTrinh?.TramDiNavigation?.TenTram
                            <i class="bi bi-arrow-right mx-1"></i>
                            @sourceTrip.LoTrinh?.TramToiNavigation?.TenTram
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="small text-muted">Xe</div>
                        <div class="fw-semibold">@sourceTrip.Xe?.BienSoXe</div>
                    </div>

                    <div class="col-md-3">
                        <div class="small text-muted">Tài xế hiện tại</div>
                        <div class="fw-semibold">@(sourceTrip.TaiXe?.HoTen ?? "Chưa phân công")</div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="NhanBan" method="post">
                <input asp-for="SourceChuyenId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="NgayDi" class="form-label">Ngày đi mới</label>
                        <input asp-for="NgayDi" class="form-control" type="date" />
                        <span asp-validation-for="NgayDi" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="GioDi" class="form-label">Giờ đi mới</label>
                        <input asp-for="GioDi" class="form-control" type="time" step="60" />
                        <span asp-validation-for="GioDi" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="GioDenDuKien" class="form-label">Giờ đến dự kiến</label>
                        <input asp-for="GioDenDuKien" class="form-control" type="time" step="60" />
                        <span asp-validation-for="GioDenDuKien" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="XeId" class="form-label">Xe sử dụng</label>
                        <select asp-for="XeId" class="form-select" asp-items="ViewBag.PrototypeXeId">
                            <option value="">-- Chọn xe --</option>
                        </select>
                        <span asp-validation-for="XeId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="TaiXeId" class="form-label">Tài xế mới (nếu muốn đổi)</label>
                        <select asp-for="TaiXeId" class="form-select" asp-items="ViewBag.PrototypeTaiXeId">
                            <option value="">-- Chưa chọn tài xế mới --</option>
                        </select>
                        <span asp-validation-for="TaiXeId" class="text-danger"></span>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="form-check">
                            <input asp-for="SaoChepHinhAnh" class="form-check-input" />
                            <label asp-for="SaoChepHinhAnh" class="form-check-label">
                                Sao chép toàn bộ ảnh của chuyến gốc
                            </label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-check">
                            <input asp-for="SaoChepTaiXe" class="form-check-input" />
                            <label asp-for="SaoChepTaiXe" class="form-check-label">
                                Nếu không chọn tài xế mới thì sao chép tài xế cũ
                            </label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-check">
                            <input asp-for="ResetTrangThaiChoDuyet" class="form-check-input" />
                            <label asp-for="ResetTrangThaiChoDuyet" class="form-check-label">
                                Đặt trạng thái chuyến mới về Chờ duyệt
                            </label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-copy"></i> Tạo chuyến mới từ mẫu
                    </button>

                    <a asp-action="Index" class="btn btn-light border">
                        Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}   