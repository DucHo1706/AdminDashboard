@model AdminDashboard.Areas.Admin.Models.CreateNhaXeViewModel

@{
    ViewData["Title"] = "Tạo Nhà Xe Mới";
}
<style>
    body {
        background-color: #f4f6f9;
        font-family: 'Poppins', sans-serif;
    }

    .vehicle-type-page {
        padding: 30px;
    }

    .content-panel {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        padding: 30px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .page-title {
        font-weight: 700;
        font-size: 28px;
        color: #3f4c6b;
        margin: 0;
    }

        .page-title i {
            color: #ff9800;
            margin-right: 12px;
        }

    .section-title {
        font-weight: 700;
        font-size: 18px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 2px solid #f0f2f5;
        padding-bottom: 10px;
    }

    .form-label-custom {
        font-weight: 600;
        color: #5b6a82;
        font-size: 14px;
        margin-bottom: 8px;
    }

    .form-control-custom {
        border: 1px solid #e0e6ed;
        border-radius: 8px;
        padding: 12px 15px;
        font-size: 14px;
        color: #3f4c6b;
        transition: all 0.3s ease;
    }

        .form-control-custom:focus {
            border-color: #ff9800;
            box-shadow: 0 0 0 3px rgba(255, 152, 0, 0.15);
            outline: none;
        }

    .border-dashed {
        border: 2px dashed #e0e6ed !important;
    }

    .text-sm {
        font-size: 12px;
        margin-top: 4px;
        display: block;
    }

    .btn-secondary-custom {
        background-color: #fff;
        color: #6c757d;
        border: 1px solid #dee2e6;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-secondary-custom:hover {
            background-color: #e9ecef;
            color: #495057;
        }

    .btn-save {
        background: linear-gradient(135deg, #ff9800, #f57c00);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        box-shadow: 0 4px 15px rgba(255, 152, 0, 0.3);
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 152, 0, 0.4);
            color: white;
        }
</style>
<div class="vehicle-type-page">
    <div class="page-header">
        <h1 class="page-title">
            <i class="fas fa-plus-circle"></i> @ViewData["Title"]
        </h1>
        <a asp-action="Index" class="btn btn-secondary-custom">
            <i class="fas fa-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="content-panel">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="section-title text-primary mb-3">
                        <i class="fas fa-building me-2"></i>Thông tin Doanh nghiệp
                    </div>

                    <div class="mb-3">
                        <label asp-for="TenNhaXe" class="form-label-custom">Tên Nhà Xe (Thương hiệu) <span class="text-danger">*</span></label>
                        <input asp-for="TenNhaXe" class="form-control-custom" placeholder="Nhập tên nhà xe..." />
                        <span asp-validation-for="TenNhaXe" class="text-danger text-sm"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="SoDienThoaiNhaXe" class="form-label-custom">Hotline <span class="text-danger">*</span></label>
                            <input asp-for="SoDienThoaiNhaXe" class="form-control-custom" placeholder="0909..." />
                            <span asp-validation-for="SoDienThoaiNhaXe" class="text-danger text-sm"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DiaChi" class="form-label-custom">Địa chỉ trụ sở</label>
                            <input asp-for="DiaChi" class="form-control-custom" placeholder="Số nhà, đường..." />
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="section-title text-warning mb-3">
                        <i class="fas fa-user-shield me-2"></i>Cấp Tài khoản Chủ xe
                    </div>

                    <div class="p-4 bg-light rounded-3 border-dashed">
                        <div class="mb-3">
                            <label asp-for="HoTenChuXe" class="form-label-custom">Họ tên người đại diện <span class="text-danger">*</span></label>
                            <input asp-for="HoTenChuXe" class="form-control-custom bg-white" placeholder="Nguyễn Văn A" />
                            <span asp-validation-for="HoTenChuXe" class="text-danger text-sm"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EmailChuXe" class="form-label-custom">Email đăng nhập <span class="text-danger">*</span></label>
                            <input asp-for="EmailChuXe" class="form-control-custom bg-white" placeholder="email@example.com" />
                            <span asp-validation-for="EmailChuXe" class="text-danger text-sm"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MatKhauMacDinh" class="form-label-custom">Mật khẩu mặc định</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted"><i class="fas fa-key"></i></span>
                                <input asp-for="MatKhauMacDinh" class="form-control-custom border-start-0 bg-white ps-0" value="123456" />
                            </div>
                            <small class="text-muted fst-italic mt-1 d-block">
                                <i class="fas fa-info-circle me-1"></i>Chủ xe sẽ đổi mật khẩu sau khi đăng nhập lần đầu.
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-actions mt-4 pt-3 border-top d-flex gap-3 justify-content-end">
                <a asp-action="Index" class="btn btn-light btn-lg px-4 border">Hủy bỏ</a>
                <button type="submit" class="btn btn-save btn-lg px-5">
                    <i class="fas fa-check-circle me-2"></i> Hoàn tất & Tạo
                </button>
            </div>
        </form>
    </div>
</div>

