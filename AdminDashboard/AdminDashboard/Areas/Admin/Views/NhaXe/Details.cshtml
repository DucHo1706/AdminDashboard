@model AdminDashboard.Models.NhaXe

@{
    ViewData["Title"] = "Thông Tin Chi Tiết";
}

<style>
    body {
        background-color: #f4f6f9;
        font-family: 'Poppins', sans-serif;
    }

    .vehicle-type-page {
        padding: 30px;
    }

    .content-panel {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        padding: 30px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .page-title {
        font-weight: 700;
        font-size: 28px;
        color: #3f4c6b;
        margin: 0;
    }

        .page-title i {
            color: #ff9800;
            margin-right: 12px;
        }

    .btn-secondary-custom {
        background-color: #fff;
        color: #6c757d;
        border: 1px solid #dee2e6;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s;
        text-decoration: none;
    }

        .btn-secondary-custom:hover {
            background-color: #e9ecef;
            color: #495057;
        }

    .section-title {
        font-weight: 700;
        font-size: 16px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid #eee;
        padding-bottom: 10px;
    }

    .profile-avatar {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #e3f2fd, #bbdefb);
        color: #0d6efd;
        font-size: 40px;
        font-weight: 800;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 4px solid #fff;
        box-shadow: 0 5px 15px rgba(13, 110, 253, 0.2);
    }

    .status-badge {
        border-radius: 30px;
        font-weight: 600;
        display: inline-block;
    }

    .status-active {
        background-color: #d1e7dd;
        color: #0f5132;
    }

    .status-inactive {
        background-color: #fff3cd;
        color: #856404;
    }

    .detail-item {
        background-color: #f8f9fa;
        padding: 15px;
        border-radius: 10px;
        border: 1px solid #f0f2f5;
        height: 100%;
    }

    .detail-label {
        font-size: 12px;
        color: #8c96a5;
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 5px;
        display: block;
    }

    .detail-value {
        font-size: 15px;
        color: #3f4c6b;
        font-weight: 500;
        word-break: break-word;
    }

    .text-monospace {
        font-family: 'Consolas', monospace;
        letter-spacing: 0.5px;
    }

</style>
<div class="vehicle-type-page">
    <div class="page-header">
        <h1 class="page-title">
            <i class="fas fa-info-circle"></i> @ViewData["Title"]
        </h1>
        <a asp-action="Index" class="btn btn-secondary-custom">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="content-panel text-center h-100">
                <div class="profile-avatar mb-3 mx-auto">
                    @Model.TenNhaXe.Substring(0, 1).ToUpper()
                </div>

                <h3 class="fw-bold text-dark mb-1">@Model.TenNhaXe</h3>
                <p class="text-muted mb-3">Đối tác vận tải</p>

                <div class="mb-4">
                    @if (Model.TrangThai == 1)
                    {
                        <span class="status-badge status-active px-3 py-2 fs-6">
                            <i class="fas fa-check-circle me-1"></i> Đang hoạt động
                        </span>
                    }
                    else
                    {
                        <span class="status-badge status-inactive px-3 py-2 fs-6">
                            <i class="fas fa-lock me-1"></i> Đang khóa / Chờ duyệt
                        </span>
                    }
                </div>

                <div class="d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.NhaXeId" class="btn btn-warning text-white fw-bold py-2">
                        <i class="fas fa-edit"></i> Chỉnh sửa thông tin
                    </a>
                    <button class="btn btn-outline-danger py-2">
                        <i class="fas fa-ban"></i> Khóa tài khoản
                    </button>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="content-panel h-100">
                <div class="section-title text-primary mb-4">
                    <i class="fas fa-building me-2"></i>Hồ sơ doanh nghiệp
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="detail-item">
                            <label class="detail-label">Mã định danh (ID)</label>
                            <div class="detail-value text-monospace">
                                <i class="fas fa-fingerprint me-2 text-muted opacity-50"></i>@Model.NhaXeId
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="detail-item">
                            <label class="detail-label">Hotline liên hệ</label>
                            <div class="detail-value text-primary">
                                <i class="fas fa-phone-alt me-2 text-muted opacity-50"></i>
                                <a href="tel:@Model.SoDienThoai" class="text-decoration-none fw-bold">@Model.SoDienThoai</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="detail-item">
                            <label class="detail-label">Địa chỉ trụ sở</label>
                            <div class="detail-value">
                                <i class="fas fa-map-marker-alt me-2 text-muted opacity-50"></i>@Model.DiaChi
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="section-title text-warning mb-4">
                    <i class="fas fa-user-tie me-2"></i>Người đại diện & Tài khoản
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="detail-item">
                            <label class="detail-label">Ngày tham gia hệ thống</label>
                            <div class="detail-value">
                                <i class="far fa-calendar-alt me-2 text-muted opacity-50"></i>
                                @DateTime.Now.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="detail-item">
                            <label class="detail-label">Số lượng xe đăng ký</label>
                            <div class="detail-value">
                                <i class="fas fa-bus me-2 text-muted opacity-50"></i>
                                <span class="badge bg-light text-dark border">12 Xe</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
