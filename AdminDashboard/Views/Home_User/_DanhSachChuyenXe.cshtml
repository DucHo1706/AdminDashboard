@using AdminDashboard.Models.TrangThai
@model IEnumerable<AdminDashboard.Models.ChuyenXe>

@* Bỏ logic lọc ở đây, chỉ trực tiếp sử dụng Model mà Controller truyền sang *@

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning text-center mt-4 mb-4">
        <i class="bi bi-emoji-frown fs-4"></i><br />
        Không tìm thấy chuyến xe nào phù hợp với yêu cầu của bạn.
    </div>
}
else
{
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Tuyến xe</th>
                    <th>Ngày đi</th>
                    <th>Giờ đi</th>
                    <th>Giờ đến dự kiến</th>
                    <th>Biển số xe</th>
                    <th>Giá vé</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cx in Model)
                {
                    <tr>
                        <td>
                            <span class="route">@cx.LoTrinh?.TramDiNavigation?.TenTram</span>
                            <i class="bi bi-arrow-right arrow"></i>
                            <span class="route">@cx.LoTrinh?.TramToiNavigation?.TenTram</span>
                        </td>
                        <td>@cx.NgayDi.ToString("dd/MM/yyyy")</td>
                        <td>@cx.GioDi.ToString(@"hh\:mm")</td>
                        <td>@cx.GioDenDuKien.ToString(@"hh\:mm")</td>
                        <td>@cx.Xe?.BienSoXe</td>
                        <td>
                            <span class="price-card">
                                @String.Format("{0:N0} đ", cx.LoTrinh.GiaVeCoDinh)
                            </span>
                        </td>
                        <td>
                            <a asp-action="ChonGhe"
                               asp-controller="Booking"
                               asp-route-chuyenId="@cx.ChuyenId"
                               class="btn btn-tuyen">
                                Chọn chuyến
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}