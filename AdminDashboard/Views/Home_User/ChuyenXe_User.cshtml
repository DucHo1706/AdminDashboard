@using AdminDashboard.Models.TrangThai
@model IEnumerable<AdminDashboard.Models.ChuyenXe>

@{
    Layout = "_Layout_User";
    ViewData["Title"] = "Chuyến Xe";
}

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: url('https://img1.kienthucvui.vn/uploads/2021/01/13/phong-canh-thun-lung-bac-son-viet-nam-dep-nhu-tranh-ve_030119832.jpg') no-repeat center center fixed;
            background-size: cover;
        }

        .search-box {
            background: rgba(255,255,255,0.95);
            border-radius: 50px;
            padding: 10px;
            display: flex;
            gap: 10px;
        }

        .table-wrapper {
            margin-top: 30px;
            background: white;
            border-radius: 10px;
            padding: 20px;
        }

        .sort-btn {
            margin-top: 20px;
        }
    </style>
</head>

<body>
    <div class="container mt-5">
        <h2 class="text-center text-white mb-4">Lịch trình xe khách</h2>

        <!-- SEARCH -->
        <form id="searchForm" class="search-box">
            <select id="diemDi" class="form-select">
                <option value="">Điểm đi</option>
                @foreach (var item in ViewBag.DanhSachTram)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>

            <select id="diemDen" class="form-select">
                <option value="">Điểm đến</option>
                @foreach (var item in ViewBag.DanhSachTram)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>

            <button type="submit" class="btn btn-warning">Tìm</button>
        </form>

        <!-- SORT -->
        <div class="text-center sort-btn">
            <button id="sortDate" class="btn btn-warning me-2">Sort theo ngày</button>
            <button id="sortPrice" class="btn btn-success">Sort theo giá</button>
        </div>

        <!-- RESULT -->
        <div id="ketQuaTimKiem" class="mt-4" style="display:none;">
            <div id="dsChuyenXe"></div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

    <script>
        let currentSort = "date"; // mặc định

        function loadData() {
            const diemDi = $('#diemDi').val();
            const diemDen = $('#diemDen').val();

            $('#ketQuaTimKiem').show();
            $('#dsChuyenXe').html("<div class='text-center'>Đang tải...</div>");

            $.ajax({
                url: '/Home_User/TimKiemAjax',
                type: 'GET',
                data: {
                    diemDi: diemDi,
                    diemDen: diemDen,
                    sortType: currentSort
                },
                success: function (data) {
                    $('#dsChuyenXe').html(data);
                },
                error: function () {
                    $('#dsChuyenXe').html("<div class='text-danger text-center'>Lỗi load dữ liệu</div>");
                }
            });
        }

        // SEARCH
        $('#searchForm').submit(function (e) {
            e.preventDefault();
            currentSort = "date"; // reset về ngày khi search
            loadData();
        });

        // SORT NGÀY
        $('#sortDate').click(function () {
            currentSort = "date";
            loadData();
        });

        // SORT GIÁ
        $('#sortPrice').click(function () {
            currentSort = "price";
            loadData();
        });
    </script>
</body>